  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="ParallelECommerce - First 5 Requirements">
      <stringProp name="TestPlan.comments">Official JMeter test plan for the first five requirements: race condition, capacity control, async queue, batch processing, and load balancing. Run against the local API and capture Summary Report plus View Results Tree screenshots.</stringProp>
